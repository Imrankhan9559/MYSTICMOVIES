# Render Free Tier - Example .env (fill your secrets)

# Core app
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH
BOT_TOKEN=YOUR_BOT_TOKEN
SESSION_STRING=YOUR_SESSION_STRING
MONGO_URI=YOUR_MONGO_URI
# Mongo driver tuning (Atlas/Render stability)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_POOL_SIZE=80
MONGO_MIN_POOL_SIZE=5
ADMIN_PHONE=+910000000000
BOT_USERNAME=your_bot_username
TMDB_API_KEY=your_tmdb_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Storage (prefer channel, avoid "me" for speed)
STORAGE_CHANNEL_ID=your_channel_id
# or
STORAGE_CHANNEL_USERNAME=your_channel

# Download speed tuning (high throughput)
DL_WORKERS_DOWNLOAD=8
DL_STRIPE_MB_DOWNLOAD=8

# Streaming tuning (balanced to reduce buffering)
DL_WORKERS=6
DL_STRIPE_MB=4

# Telethon download chunk size (MB)
TL_CHUNK_MB=8

# Startup reliability (Render)
# Keep these false so web service still boots even if Telegram is temporarily unavailable.
TELEGRAM_STARTUP_REQUIRED=false
TELETHON_STARTUP_REQUIRED=false
DB_INIT_ATTEMPTS=5
DB_INIT_DELAY_SEC=2.0

# Request timing / slow endpoint logs
# Enable HTTP timing middleware and top slow-endpoint summary logs.
REQUEST_TIMING_ENABLED=true
# Log request as slow when response time crosses this threshold (milliseconds).
REQUEST_TIMING_SLOW_MS=1200
# Log every request (true) or only slow/5xx requests (false).
REQUEST_TIMING_LOG_ALL=false
# Summary interval for top slow endpoints (seconds).
REQUEST_TIMING_FLUSH_SEC=60
# Number of endpoints to include in periodic summary.
REQUEST_TIMING_TOP_N=8
# Comma-separated path prefixes to skip timing logs.
REQUEST_TIMING_EXCLUDE_PATHS=/favicon.ico,/static,/healthz

# Content catalog responsiveness (public /content + search pages)
CONTENT_CATALOG_CACHE_TTL_SEC=120
CONTENT_CATALOG_QUERY_TIMEOUT_SEC=8
CONTENT_RELATED_CACHE_TTL_SEC=120
CONTENT_RELATED_QUERY_TIMEOUT_SEC=6
CONTENT_RELATED_QUERY_LIMIT=220

# Mass uploader snapshot/dedupe tuning
MASS_SNAPSHOT_ROW_LIMIT=320
MASS_DEDUPE_SCAN_LIMIT=12000
MASS_DEDUPE_MAX_RUNTIME_SEC=3.0
MASS_EXPORT_ROW_LIMIT=20000

# Optional bot pool (comma-separated BOT tokens)
# BOT_POOL_TOKENS=token1,token2
