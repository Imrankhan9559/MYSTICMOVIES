# Render Free Tier - Example .env (fill your secrets)

# Core app
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH
BOT_TOKEN=YOUR_BOT_TOKEN
SESSION_STRING=YOUR_SESSION_STRING
MONGO_URI=YOUR_MONGO_URI
ADMIN_PHONE=+910000000000
BOT_USERNAME=your_bot_username

# Storage (prefer channel, avoid "me" for speed)
STORAGE_CHANNEL_ID=your_channel_id
# or
STORAGE_CHANNEL_USERNAME=your_channel

# Download speed tuning (high throughput)
DL_WORKERS_DOWNLOAD=8
DL_STRIPE_MB_DOWNLOAD=8

# Streaming tuning (balanced to reduce buffering)
DL_WORKERS=6
DL_STRIPE_MB=4

# Telethon download chunk size (MB)
TL_CHUNK_MB=8

# Request timing / slow endpoint logs
REQUEST_TIMING_ENABLED=true
REQUEST_TIMING_SLOW_MS=1200
REQUEST_TIMING_LOG_ALL=false
REQUEST_TIMING_FLUSH_SEC=60
REQUEST_TIMING_TOP_N=8
REQUEST_TIMING_EXCLUDE_PATHS=/favicon.ico,/static,/healthz
